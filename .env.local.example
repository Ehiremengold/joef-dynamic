# ---- Supabase ----
# From Supabase → Project Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
# Keep this SECRET — server only. Never prefix with NEXT_PUBLIC.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ---- Sessions ----
# Signs student/candidate cookies. Use a long random string (>= 32 chars).
# Generate: node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
SESSION_SECRET=change-me-to-a-long-random-string

# ---- Subdomain (production) ----
# Leave unset locally. In production set to your portal host so the middleware
# maps portal.joefdynamicschools.com → the portal and keeps it off the apex.
NEXT_PUBLIC_PORTAL_HOST=portal.joefdynamicschools.com

# ---- First admin (used once by scripts/seed-admin.mjs) ----
FIRST_ADMIN_NAME=Head Teacher
FIRST_ADMIN_EMAIL=admin@joefdynamicschools.com
FIRST_ADMIN_PASSWORD=change-this-strong-password
